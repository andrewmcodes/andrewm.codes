{"expires":1784338482.642,"value":{"highlighted":"<!-- Syntax highlighted by torchlight.dev --><div class='line'><span style=\"color: #abb2bf;\">TABLE WITHOUT ID</span></div><div class='line'><span style=\"color: #abb2bf;\">  file.link as Date,</span></div><div class='line'><span style=\"color: #abb2bf;\">  choice(exercise &gt; 30, &quot;✅&quot;, &quot;❌&quot;) as Exercise,</span></div><div class='line'><span style=\"color: #abb2bf;\">  choice(sleep &gt; 6, &quot;✅&quot;, &quot;❌&quot;) as Sleep,</span></div><div class='line'><span style=\"color: #abb2bf;\">  choice(highlights &gt;= 3, &quot;✅&quot;, &quot;❌&quot;) as Highlights,</span></div><div class='line'><span style=\"color: #abb2bf;\">  choice(mindfulness &gt; 10, &quot;✅&quot;, &quot;❌&quot;) as Mindfulness,</span></div><div class='line'><span style=\"color: #abb2bf;\">  reading as Reading</span></div><div class='line'><span style=\"color: #abb2bf;\">FROM &quot;daily&quot;</span></div><div class='line'><span style=\"color: #abb2bf;\">WHERE file.day &lt;= date(now) AND file.day &gt;= date(now) - dur(7days)</span></div><div class='line'><span style=\"color: #abb2bf;\">SORT file.day ASC</span></div>","classes":"torchlight","styles":"background-color: #282c34; --theme-selection-background: #2c313a;"}}
