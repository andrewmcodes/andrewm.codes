---
layout: default
---

<%= render PageShell.new(width: :narrow) do %>
  <% if data.title %>
    <%= render Ui::PageHeader.new(title: data.title, description: data.description) %>
  <% end %>

  <%= render Prose.new(as: :article, variant: :page, max_w: false) do %>
    <%= yield %>
  <% end %>
<% end %>
