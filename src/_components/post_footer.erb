<footer class="mt-16 pt-7 border-t border-sage-5">
  <%= render PostFooterNav.new(
    previous_resource: previous_resource,
    next_resource: next_resource,
  ) %>

  <%= render Inline.new(gap: :sm, class_name: "mt-4") do %>
    <%= render ShareButton.new(resource: resource) %>
  <% end %>

  <%= render RelatedPosts.new(posts: helpers.related_posts(resource)) %>
</footer>
