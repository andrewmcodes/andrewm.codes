<div
  role="radiogroup"
  aria-label="<%= group_label %>"
  data-theme-toggle
  class="inline-flex items-center gap-0.5 p-1 rounded-full bg-sage-3"
>
  <button
    type="button"
    role="radio"
    data-theme-value="system"
    aria-checked="true"
    tabindex="0"
    aria-label="Sync theme with system"
    title="System"
    class="
      size-9 rounded-full inline-flex items-center justify-center text-sage-10 cursor-pointer
      hover:text-sage-12 transition-colors focus-visible:outline-none focus-visible:ring-2
      focus-visible:ring-mint-8 aria-checked:bg-sage-5 aria-checked:text-sage-12
    "
  >
    <svg
      width="15"
      height="15"
      viewBox="0 0 24 24"
      fill="none"
      stroke="currentColor"
      stroke-width="2"
      stroke-linecap="round"
      stroke-linejoin="round"
      aria-hidden="true"
    ><rect x="2" y="3" width="20" height="14" rx="2"/><path d="M8 21h8M12 17v4"/></svg>
  </button>

  <button
    type="button"
    role="radio"
    data-theme-value="light"
    aria-checked="false"
    tabindex="-1"
    aria-label="Use light theme"
    title="Light"
    class="
      size-9 rounded-full inline-flex items-center justify-center text-sage-10 cursor-pointer
      hover:text-sage-12 transition-colors focus-visible:outline-none focus-visible:ring-2
      focus-visible:ring-mint-8 aria-checked:bg-sage-5 aria-checked:text-sage-12
    "
  >
    <svg
      width="15"
      height="15"
      viewBox="0 0 24 24"
      fill="none"
      stroke="currentColor"
      stroke-width="2"
      stroke-linecap="round"
      stroke-linejoin="round"
      aria-hidden="true"
    ><circle cx="12" cy="12" r="4"/><path
        d="M12 2v2M12 20v2M4.93 4.93l1.41 1.41M17.66 17.66l1.41 1.41M2 12h2M20 12h2M4.93 19.07l1.41-1.41M17.66 6.34l1.41-1.41"
      /></svg>
  </button>

  <button
    type="button"
    role="radio"
    data-theme-value="dark"
    aria-checked="false"
    tabindex="-1"
    aria-label="Use dark theme"
    title="Dark"
    class="
      size-9 rounded-full inline-flex items-center justify-center text-sage-10 cursor-pointer
      hover:text-sage-12 transition-colors focus-visible:outline-none focus-visible:ring-2
      focus-visible:ring-mint-8 aria-checked:bg-sage-5 aria-checked:text-sage-12
    "
  >
    <svg
      width="15"
      height="15"
      viewBox="0 0 24 24"
      fill="none"
      stroke="currentColor"
      stroke-width="2"
      stroke-linecap="round"
      stroke-linejoin="round"
      aria-hidden="true"
    ><path d="M21 12.8A9 9 0 1 1 11.2 3a7 7 0 0 0 9.8 9.8Z"/></svg>
  </button>
</div>
