<aside
  role="note"
  class="mb-10 rounded-md border border-sage-5 bg-sage-2 p-4 text-[13px] text-sage-11 leading-relaxed"
>
  <%= render Inline.new(gap: :sm, align: :start) do %>
    <%= render Icon.new(name: "warning", size: :sm, class: "text-sage-11") %>
    <p class="m-0">
      <span class="font-mono text-xs uppercase tracking-wide text-sage-12">Heads up:</span>
      this post was last updated
      <%= render Util::Time.new(date: updated_at, format: :month_year, class_name: "dt-updated") %>. Tools, versions, and best practices may have moved on since then.
    </p>
  <% end %>
</aside>
