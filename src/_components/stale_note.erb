<aside
  role="note"
  class="
    mb-10 rounded-lg border border-amber-500/30 bg-amber-500/5 p-4 text-[14px]
    text-sage-12 leading-relaxed
  "
>
  <div class="flex items-start gap-3">
    <svg
      width="16"
      height="16"
      viewBox="0 0 24 24"
      fill="none"
      stroke="currentColor"
      stroke-width="2"
      stroke-linecap="round"
      stroke-linejoin="round"
      class="text-amber-500 mt-0.5 shrink-0"
      aria-hidden="true"
    >
      <circle cx="12" cy="12" r="10"/>
      <path d="M12 8v4M12 16h.01"/>
    </svg>
    <div>
      <strong class="font-medium">Heads up:</strong>
      this post was last updated
      <time datetime="<%= datetime %>"><%= label %></time>. Tools, versions, and best practices may have moved on since then.
    </div>
  </div>
</aside>
