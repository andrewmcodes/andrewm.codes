<header
  class="sticky top-0 z-40 bg-sage-1/85 backdrop-blur backdrop-saturate-150"
>
  <div class="<%= shell_width %> mx-auto w-full">
    <div class="flex items-center gap-4 h-16 max-compact:h-14 max-compact:gap-2">
      <%= render Link.new(href: "/", variant: :brand) do %>
        <span class="w-9 h-9 rounded-full shrink-0 bg-mint-9"></span>
        <span class="text-sm text-sage-12"><%= metadata.author.name %></span>
        <span class="text-sage-8 mx-0.5 font-normal max-compact:hidden">/</span>
        <%= render Text.new(as: :span, variant: :meta, class: "max-compact:hidden") do %>@<%= metadata.handle %><% end %>
      <% end %>

      <nav aria-label="Primary" class="ml-auto flex items-center gap-0.5">
        <% nav_items.each do |item| %>
          <%= render Link.new(href: item.url, variant: :nav, class: nav_item_class(item)) do %><%= item.label %><% end %>
        <% end %>

        <%= render Inline.new(gap: :sm, wrap: false, class: "ml-2 max-compact:gap-0.5 max-compact:ml-1") do %>
          <button
            type="button"
            id="cmdk-trigger"
            class="
              font-mono text-xs text-sage-11 px-2.5 py-1.5 rounded-md inline-flex
              items-center gap-2 hover:bg-sage-3 hover:text-sage-12 transition-colors
              focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2
              focus-visible:outline-mint-9
            "
            aria-label="Open search"
          >
            <svg
              width="14"
              height="14"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"
              aria-hidden="true"
            ><circle cx="11" cy="11" r="7"/><path d="m20 20-3.5-3.5"/></svg>
            <span class="max-compact:hidden">Search</span>
            <kbd
              class="
                font-mono text-[11px] bg-sage-3 border border-sage-5 rounded text-sage-11 px-1.5
                py-px max-nav:hidden
              "
            >⌘K</kbd>
          </button>

          <button
            type="button"
            id="mobile-menu-trigger"
            class="
              hidden max-nav:inline-flex w-11 h-11 rounded-md items-center justify-center
              text-sage-11 hover:bg-sage-3 hover:text-sage-12 transition-colors
              focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2
              focus-visible:outline-mint-9
            "
            aria-label="Open menu"
            aria-expanded="false"
          >
            <svg
              data-menu-icon="open"
              width="16"
              height="16"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"
              aria-hidden="true"
            ><path d="M4 6h16M4 12h16M4 18h16"/></svg>
            <svg
              data-menu-icon="close"
              hidden
              width="14"
              height="14"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"
              aria-hidden="true"
            ><path d="M18 6 6 18M6 6l12 12"/></svg>
          </button>
        <% end %>
      </nav>
    </div>
  </div>

  <div
    id="mobile-menu-backdrop"
    data-open="false"
    aria-hidden="true"
    class="
      fixed inset-x-0 bottom-0 top-16 z-[34] bg-sage-1/50 backdrop-blur-sm
      transition-[opacity,visibility] duration-200 ease-out opacity-0 invisible
      pointer-events-none data-[open=true]:opacity-100 data-[open=true]:visible
      data-[open=true]:pointer-events-auto max-compact:top-14
    "
  ></div>

  <div
    id="mobile-menu"
    data-open="false"
    role="dialog"
    aria-modal="true"
    aria-label="Site menu"
    inert
    class="
      fixed inset-x-0 top-16 z-[35] origin-top bg-sage-1/95 backdrop-blur border-b
      border-sage-4 rounded-b-2xl px-2 pt-2 pb-3
      transition-[opacity,transform] duration-200 ease-out opacity-0
      -translate-y-2 pointer-events-none data-[open=true]:opacity-100
      data-[open=true]:translate-y-0
      data-[open=true]:pointer-events-auto max-compact:top-14
    "
  >
    <nav aria-label="Mobile" class="flex flex-col gap-0.5">
      <% nav_items.each do |item| %>
        <%= render Link.new(
          href: item.url,
          variant: :nav_mobile,
          class: mobile_item_class(item),
          "aria-current": (active?(item.url) ? "page" : nil),
        ) do %>
          <span><%= item.label %></span>
          <svg
            width="16"
            height="16"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
            aria-hidden="true"
            class="<%= mobile_chevron_class(item) %>"
          ><path d="m9 18 6-6-6-6"/></svg>
        <% end %>
      <% end %>
    </nav>

    <%= render Inline.new(gap: :md, wrap: false, class: "mt-2 pt-3 px-2 border-t border-sage-4 justify-between") do %>
      <%= render Link.new(
        href: "/feed.xml",
        class: "inline-flex items-center gap-2 px-3 py-2 rounded-lg font-mono text-xs text-sage-11 hover:bg-sage-3 hover:text-sage-12 transition-colors",
      ) do %>
        <svg
          width="15"
          height="15"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
          aria-hidden="true"
        ><path d="M4 11a9 9 0 0 1 9 9M4 4a16 16 0 0 1 16 16"/><circle
            cx="5"
            cy="19"
            r="1"
          /></svg>
        RSS
      <% end %>

      <%= render ThemeToggle.new(context: "menu") %>
    <% end %>
  </div>
</header>
