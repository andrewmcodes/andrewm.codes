<header class="sticky top-0 z-40 bg-sage-1/85 backdrop-blur backdrop-saturate-150">
  <div class="max-w-[1080px] mx-auto w-full px-9 max-md:px-4">
    <div class="flex items-center gap-4 h-16 max-compact:h-14 max-compact:gap-2">
      <a
        href="/"
        class="inline-flex items-center gap-3 font-semibold tracking-tight"
      >
        <span class="w-9 h-9 rounded-full shrink-0 bg-mint-9"></span>
        <span class="text-sm text-sage-12"><%= metadata.author.name %></span>
        <span class="text-sage-8 mx-0.5 font-normal max-compact:hidden">/</span>

        <span
          class="
            text-sage-11 text-[12.5px] font-mono font-normal
            max-compact:hidden
          "
        >
          @<%= metadata.handle %>
        </span>
      </a>

      <nav aria-label="Primary" class="ml-auto flex items-center gap-0.5">
        <% nav_items.each do |item| %>
          <% next if item.label == "RSS" %>

          <a
            href="<%= item.url %>"
            <% if active?(item.url) %>
              aria-current="page"
            <% end %>
            class="
              px-2.5 py-1.5 text-[13.5px] rounded-md transition-colors hover:bg-sage-3
              hover:text-sage-12 <%= active?(item.url) ? "text-sage-12 relative after:absolute after:left-2.5 after:right-2.5 after:bottom-0.5 after:h-[1.5px] after:bg-mint-11 after:rounded-sm" : "text-sage-11" %> max-nav:hidden
            "
          >
            <%= item.label %>
          </a>
        <% end %>

        <div
          class="
            flex items-center gap-1.5 ml-2 max-compact:gap-0.5
            max-compact:ml-1
          "
        >
          <button
            type="button"
            id="cmdk-trigger"
            class="
              font-mono text-[11.5px] text-sage-11 px-2.5 py-1.5 rounded-md inline-flex
              items-center gap-2 hover:bg-sage-3 hover:text-sage-12 transition-colors
            "
            aria-label="Open search"
          >
            <svg
              width="14"
              height="14"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"
              aria-hidden="true"
            >
              <circle cx="11" cy="11" r="7" />
              <path d="m20 20-3.5-3.5" />
            </svg>

            <span class="max-compact:hidden">Search</span>

            <kbd
              class="
                font-mono text-[11px] bg-sage-3 border border-sage-5 rounded text-sage-11 px-1.5
                py-px max-nav:hidden
              "
            >
              ⌘K
            </kbd>
          </button>

          <button
            type="button"
            id="mobile-menu-trigger"
            class="
              hidden max-nav:inline-flex w-9 h-9 rounded-md items-center justify-center
              text-sage-11 hover:bg-sage-3 hover:text-sage-12 transition-colors
            "
            aria-label="Open menu"
            aria-expanded="false"
          >
            <svg
              data-menu-icon="open"
              width="16"
              height="16"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"
              aria-hidden="true"
            >
              <path d="M4 6h16M4 12h16M4 18h16" />
            </svg>

            <svg
              data-menu-icon="close"
              hidden
              width="14"
              height="14"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"
              aria-hidden="true"
            >
              <path d="M18 6 6 18M6 6l12 12" />
            </svg>
          </button>
        </div>
      </nav>
    </div>
  </div>

  <div
    id="mobile-menu-backdrop"
    data-open="false"
    aria-hidden="true"
    class="
      fixed inset-x-0 bottom-0 top-16 z-[34] bg-sage-1/50 backdrop-blur-sm
      transition-[opacity,visibility] duration-200 ease-out opacity-0 invisible
      pointer-events-none data-[open=true]:opacity-100 data-[open=true]:visible
      data-[open=true]:pointer-events-auto max-compact:top-14
    "
  ></div>

  <div
    id="mobile-menu"
    data-open="false"
    role="dialog"
    aria-modal="true"
    aria-label="Site menu"
    inert
    class="
      fixed inset-x-0 top-16 z-[35] origin-top bg-sage-1/95 backdrop-blur border-b
      border-sage-4 rounded-b-2xl shadow-xl px-2 pt-2 pb-3
      transition-[opacity,transform] duration-200 ease-out opacity-0
      -translate-y-2 pointer-events-none data-[open=true]:opacity-100
      data-[open=true]:translate-y-0
      data-[open=true]:pointer-events-auto max-compact:top-14
    "
  >
    <nav aria-label="Mobile" class="flex flex-col gap-0.5">
      <% nav_items.each do |item| %>
        <% next if item.label == "RSS" %>

        <a
          href="<%= item.url %>"
          <% if active?(item.url) %>
            aria-current="page"
          <% end %>
          class="
              group flex items-center justify-between gap-3 px-4 py-3 rounded-xl text-[15px]
              transition-colors <%= active?(item.url) ? "bg-mint-3 text-mint-11 font-medium" : "text-sage-11 hover:bg-sage-3 hover:text-sage-12" %>
            "
        >
          <span><%= item.label %></span>

          <svg
            width="16"
            height="16"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
            aria-hidden="true"
            class="<%= active?(item.url) ? "text-mint-11" : "text-sage-7 -translate-x-1 opacity-0 transition group-hover:translate-x-0 group-hover:opacity-100" %>"
          >
            <path d="m9 18 6-6-6-6" />
          </svg>
        </a>
      <% end %>
    </nav>

    <div
      class="
        mt-2 pt-3 px-2 border-t border-sage-4 flex items-center
        justify-between gap-3
      "
    >
      <a
        href="/feed.xml"
        class="
          inline-flex items-center gap-2 px-3 py-2 rounded-lg font-mono text-[12.5px]
          text-sage-11 hover:bg-sage-3 hover:text-sage-12 transition-colors
        "
      >
        <svg
          width="15"
          height="15"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
          aria-hidden="true"
        >
          <path d="M4 11a9 9 0 0 1 9 9M4 4a16 16 0 0 1 16 16" />
          <circle cx="5" cy="19" r="1" />
        </svg>
        RSS
      </a>

      <%= render ThemeToggle.new(context: "menu") %>
    </div>
  </div>
</header>
