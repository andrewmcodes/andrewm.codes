<%= render Link.new(href: href, external: external?, class: row_classes) do %>
  <%= render Text.new(as: :div, variant: :meta, class: "whitespace-nowrap") do %><%= date %><% end %>
  <div>
    <%= render Text.new(as: :div, variant: :row_title, class: title_wrap_classes) do %>
      <% if title_icon? %>
        <span><%= title %></span>
        <%= render Icon.new(
          name: icon_name,
          class: "text-sage-8 group-hover:text-mint-11 transition-colors shrink-0 inline-block translate-y-px",
        ) %>
      <% else %>
        <%= title %>
      <% end %>
    <% end %>
    <% if meta.any? %>
      <%= render Inline.new(gap: :sm, class: "mt-1") do %>
        <% meta.each_with_index do |item, i| %>
          <% if i > 0 %>
            <%= render Text.new(as: :span, variant: :meta) do %>·<% end %>
          <% end %>
          <%= render Text.new(as: :span, variant: :meta) do %><%= item %><% end %>
        <% end %>
      <% end %>
    <% end %>
  </div>
  <% unless title_icon? %>
    <div class="max-md:hidden inline-flex items-center justify-end">
      <%= render Icon.new(
        name: icon_name,
        class: "text-sage-8 group-hover:text-mint-11 transition-colors",
      ) %>
    </div>
  <% end %>
<% end %>
