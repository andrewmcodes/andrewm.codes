<h1
  class="
    text-[clamp(28px,4vw,40px)] leading-[1.15] tracking-tight font-bold m-0 mb-4
    text-balance text-sage-12
  "
>
  <%= title %>
</h1>

<div class="flex flex-wrap items-center gap-3.5 font-mono text-xs text-sage-11 mb-5">
  <time datetime="<%= date.iso8601 %>"><%= date.strftime("%b %-d, %Y") %></time>
  <span>·</span>
  <span><%= reading_time %> min read</span>
  <span>·</span>

  <a
    href="/about/"
    rel="author"
    class="text-sage-11 hover:text-mint-11 transition-colors"
  >
    <%= author_name %>
  </a>

  <% if tags.any? %>
    <span>·</span>
    <% tags.each do |tag| %>
    <%= render Link.new(href: "/tag/#{tag_slug(tag)}/", variant: :post_tag) do %>
        #<%= tag %>
      <% end %>
    <% end %>
  <% end %>
</div>

<div class="mb-10">
  <%= render MarkdownActions.new(resource: resource) %>
</div>
