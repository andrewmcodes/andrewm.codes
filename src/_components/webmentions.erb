<% if reactions.any? || replies.any? %>
  <section class="mt-12 pt-7 border-t border-sage-5">
    <h2 class="font-mono text-[12.5px] uppercase tracking-wide text-sage-11">Webmentions</h2>

    <% if reactions.any? %>
      <div class="mt-4 flex flex-wrap items-center gap-2">
        <% reactions.first(40).each do |wm| %>
          <% a = author_of(wm) %>
          <%= render Link.new(href: a["url"] || wm["url"], external: true, class_name: "shrink-0") do %>
            <% if a["photo"] %>
              <%= render Image.new(
                src: a["photo"],
                alt: a["name"] || "Someone",
                variant: :avatar,
                width: 24,
                height: 24,
              ) %>
            <% else %>
              <span class="inline-block h-6 w-6 rounded-full bg-sage-4"></span>
            <% end %>
          <% end %>
        <% end %>
        <span class="font-mono text-xs text-sage-11">
          <%= reactions.length %>
          <%= (reactions.length == 1) ? "reaction" : "reactions" %>
        </span>
      </div>
    <% end %>

    <% if replies.any? %>
      <ul class="mt-6 space-y-5">
        <% replies.each do |wm| %>
          <% a = author_of(wm) %>
          <li class="flex gap-3">
            <% if a["photo"] %>
              <%= render Image.new(
                src: a["photo"],
                alt: a["name"] || "Someone",
                variant: :avatar,
                width: 24,
                height: 24,
              ) %>
            <% end %>
            <div class="min-w-0">
              <div class="flex items-baseline gap-2">
                <%= render Link.new(href: a["url"] || wm["url"], external: true, weight: :medium, scheme: :strong) do %>
                  <%= a["name"] || "Someone" %>
                <% end %>
                <% if published_on(wm) %>
                  <span class="font-mono text-[11px] text-sage-11"><%= published_on(wm) %></span>
                <% end %>
              </div>
              <% if content_text(wm) %>
                <p class="mt-1 text-sm text-sage-11 break-words"><%= content_text(wm) %></p>
              <% end %>
            </div>
          </li>
        <% end %>
      </ul>
    <% end %>
  </section>
<% end %>
