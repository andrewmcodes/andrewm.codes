<% if reactions.any? || replies.any? %>
  <section class="mt-12 pt-7 border-t border-sage-5">
    <%= render Text.new(as: :h2, variant: :meta, class: "uppercase tracking-wide") do %>Webmentions<% end %>

    <% if reactions.any? %>
      <%= render Inline.new(gap: :sm, wrap: true, class_name: "mt-4") do %>
        <% reactions.first(40).each do |wm| %>
          <% a = author_of(wm) %>
          <%= render Link.new(href: a["url"] || wm["url"], external: true, class_name: "shrink-0") do %>
            <% if a["photo"] %>
              <%= render Image.new(
                src: a["photo"],
                alt: a["name"] || "Someone",
                variant: :avatar,
                width: 24,
                height: 24,
              ) %>
            <% else %>
              <span class="inline-block h-6 w-6 rounded-full bg-sage-4"></span>
            <% end %>
          <% end %>
        <% end %>
        <%= render Text.new(as: :span, variant: :meta) do %>
          <%= reactions.length %>
          <%= (reactions.length == 1) ? "reaction" : "reactions" %>
        <% end %>
      <% end %>
    <% end %>

    <% if replies.any? %>
      <ul class="mt-6 flex flex-col gap-5">
        <% replies.each do |wm| %>
          <% a = author_of(wm) %>
          <li>
            <%= render Inline.new(gap: :sm, align: :start) do %>
              <% if a["photo"] %>
                <%= render Image.new(
                  src: a["photo"],
                  alt: a["name"] || "Someone",
                  variant: :avatar,
                  width: 24,
                  height: 24,
                ) %>
              <% end %>
              <div class="min-w-0">
                <%= render Inline.new(gap: :xs, align: :baseline) do %>
                  <%= render Link.new(href: a["url"] || wm["url"], external: true, weight: :medium, scheme: :strong) do %>
                    <%= a["name"] || "Someone" %>
                  <% end %>
                  <% if published_on(wm) %>
                    <%= render Text.new(as: :span, variant: :meta) do %><%= published_on(wm) %><% end %>
                  <% end %>
                <% end %>
                <% if content_text(wm) %>
                  <%= render Text.new(size: :md, scheme: :muted, class_name: "mt-1 break-words") do %><%= content_text(wm) %><% end %>
                <% end %>
              </div>
            <% end %>
          </li>
        <% end %>
      </ul>
    <% end %>
  </section>
<% end %>
