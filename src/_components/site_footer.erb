<footer class="border-t border-sage-4 mt-16 pt-10 pb-8" data-pagefind-ignore>
  <div class="<%= shell_width %> mx-auto w-full">
    <div
      class="
        flex flex-col gap-4 md:flex-row md:flex-wrap md:justify-between md:items-center
        font-mono text-xs text-sage-11
      "
    >
      <span><%= copyright_line %></span>

      <%= render Inline.new(gap: :md) do %>
        <%= render Inline.new(gap: :sm) do %>
          <% accounts.each_with_index do |a, i| %>
            <% if i > 0 %><span>·</span><% end %>
            <%= render Link.new(href: a["url"], variant: :underline_meta) do %><%= a["name"] %><% end %>
          <% end %>
          <span>·</span>
          <%= render Link.new(href: "/feed.xml", variant: :underline_meta) do %>RSS<% end %>
          <span>·</span>
          <%= render Link.new(href: "/feed.json", variant: :underline_meta) do %>JSON<% end %>
        <% end %>

        <%= render ThemeToggle.new %>
      <% end %>
    </div>

    <div
      class="
        mt-4 md:mt-3 flex flex-col gap-2 md:flex-row md:flex-wrap md:justify-between
        md:items-center font-mono text-[11px] text-sage-11
      "
    >
      <%= render Inline.new(gap: :sm) do %>
        <%= render Link.new(href: "/changelog/", variant: :post_nav) do %>Changelog<% end %>
        <span>·</span>
        <%= render Link.new(href: "/uses/", variant: :post_nav) do %>Uses<% end %>
        <span>·</span>
        <%= render Link.new(href: "https://github.com/#{metadata.repo}", variant: :post_nav) do %>Source<% end %>
      <% end %>

      <%= render Link.new(
        href: latest_commit_url,
        variant: :post_nav,
        class: "inline-flex items-center gap-1.5",
        title: "Latest commit",
      ) do %>
        <svg
          width="10"
          height="10"
          viewBox="0 0 16 16"
          fill="currentColor"
          aria-hidden="true"
        ><path
            d="M11.93 8.5a4.002 4.002 0 0 1-7.86 0H.75a.75.75 0 0 1 0-1.5h3.32a4.002 4.002 0 0 1 7.86 0h3.32a.75.75 0 0 1 0 1.5Zm-1.43-.75a2.5 2.5 0 1 0-5 0 2.5 2.5 0 0 0 5 0Z"
          /></svg>
        <span><%= latest_commit_sha %></span>
      <% end %>
    </div>
  </div>
</footer>
