<div
  class="md-actions relative inline-flex items-stretch font-mono text-xs text-sage-11"
  data-md-url="<%= markdown_path %>"
>
  <button
    type="button"
    class="
      md-copy inline-flex items-center gap-1.5 rounded-l-md border border-sage-5 bg-transparent
      px-2 py-1 hover:text-mint-11 hover:border-mint-11 transition-colors
      focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-mint-9
    "
  >
    <%= render Icon.new(name: "copy", class: "w-[11px] h-[11px]") %>
    <span class="md-copy-label">Copy page</span>
  </button>

  <details class="md-menu -ml-px">
    <summary
      class="
        flex h-full list-none items-center rounded-r-md border border-sage-5 px-1.5 cursor-pointer
        hover:text-mint-11 hover:border-mint-11 transition-colors
        focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-mint-9
        [&::-webkit-details-marker]:hidden
      "
      aria-label="More Markdown options"
    >
      <%= render Icon.new(name: "chevron_down", class: "w-3 h-3") %>
    </summary>

    <div
      class="
        absolute left-0 top-full z-20 mt-1 min-w-44 overflow-hidden rounded-md border border-sage-5
        bg-sage-2 py-1
      "
      role="menu"
    >
      <% menu_items.each do |item| %>
        <a
          href="<%= item[:href] %>"
          <% if item[:external] %>target="_blank" rel="noreferrer"<% else %>data-turbo="false"<% end %>
          class="<%= menu_item_class %>"
          role="menuitem"
        >
          <%= render Icon.new(name: item[:icon], class: "w-3 h-3") %>
          <%= item[:label] %>
        </a>
      <% end %>
    </div>
  </details>
</div>
