<article
  class="
    grid grid-cols-[120px_1fr] gap-5 py-5 border-b border-sage-4
    max-sm:grid-cols-1 max-sm:gap-2 max-sm:py-4
  "
>
  <div class="font-mono text-[11.5px] text-sage-10">
    <div class="text-sage-11 text-[13px] mb-1"><%= date_str %></div>
    <div class="text-[11px] text-sage-10"><%= field(:duration) %></div>
  </div>
  <div>
    <div class="font-mono text-[11.5px] text-mint-11 mb-2 lowercase"><%= field(:venue) %><% if field(:city) %>
        ·
        <%= field(:city) %><% end %></div>
    <h3 class="text-[17px] font-medium tracking-tight mb-1 text-sage-12"><%= field(:title) %></h3>
    <%= render Text.new(variant: :card_body, class: "mb-3") do %><%= field(:excerpt) %><% end %>
    <div class="flex flex-wrap gap-3.5">
      <% Array(field(:links)).each do |l| %>
        <a
          href="<%= l["href"] || l[:href] %>"
          class="
            inline-flex items-center gap-1 font-mono text-[11.5px] text-sage-10 border-b
            border-sage-5 pb-px hover:text-mint-11 hover:border-mint-11 transition-colors
            rounded-[2px] focus-visible:outline focus-visible:outline-2
            focus-visible:outline-offset-2 focus-visible:outline-mint-9
          "
        >
          <%= l["label"] || l[:label] %>
          <%= render Icon.new(name: "arrow_top_right", class: "w-3 h-3") %>
        </a>
      <% end %>
    </div>
  </div>
</article>
