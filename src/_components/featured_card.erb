<%= render Link.new(href: field(:href), external: true, class: card_classes) do %>
  <div class="flex items-center gap-2.5 mb-1">
    <%= render Text.new(as: :span, variant: :card_title, class: "inline-flex items-center gap-1.5") do %>
      <%= field(:title) %>
      <%= render Icon.new(
        name: "arrow_top_right",
        class: "w-3 h-3 text-sage-8 group-hover:text-mint-11 transition-colors",
      ) %>
    <% end %>
    <% if field(:kind) %>
      <%= render Text.new(as: :span, variant: :eyebrow, class: kind_badge_classes) do %><%= field(:kind) %><% end %>
    <% end %>
  </div>
  <%= render Text.new(as: :div, variant: :card_body, class: "my-1 mb-4") do %><%= field(:desc) %><% end %>
  <% if field(:label) %>
    <%= render Text.new(variant: :meta, class: "mt-auto") do %><%= field(:label) %><% end %>
  <% end %>
<% end %>
