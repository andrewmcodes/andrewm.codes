<%= render Link.new(
  href: @post.relative_url,
  class: row_classes,
  data_post_row: true,
  data_tags: tags_data,
) do %>
  <%= render Text.new(as: :div, variant: :meta, class: "whitespace-nowrap max-md:text-[11px]") do %><%= date_str %><% end %>
  <div>
    <%= render Text.new(as: :div, variant: :row_title, class: "text-balance") do %><%= @post.data.title %><% end %>
    <%= render Inline.new(gap: :sm, class: "mt-1") do %>
      <% tags.each do |t| %>
        <%= render Text.new(as: :span, variant: :meta) do %><span class="text-sage-8">#</span><%= t %><% end %>
      <% end %>
      <% if tags.any? %><%= render Text.new(as: :span, variant: :meta) do %>·<% end %><% end %>
      <%= render Text.new(as: :span, variant: :meta) do %><%= reading %><% end %>
    <% end %>
  </div>
  <div class="max-md:hidden inline-flex items-center justify-end">
    <%= render Icon.new(
      name: "arrow_right",
      class: "text-sage-8 group-hover:text-mint-11 group-hover:translate-x-0.5 transition-all",
    ) %>
  </div>
<% end %>
