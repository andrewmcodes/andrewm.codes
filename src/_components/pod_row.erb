<% row_component =
  if linked?
    Link.new(href: url, external: true, class: row_classes)
  else
    Box.new(class: row_classes)
  end %>
<%= render row_component do %>
  <div class="relative w-14 h-14 max-sm:w-16 max-sm:h-16 shrink-0">
    <div
      class="
        absolute inset-0 rounded-[10px] inline-flex items-center justify-center
        font-mono text-lg font-medium tracking-[-0.03em] text-sage-1 max-sm:text-sm
      "
      style="background: oklch(0.62 0.14 <%= hue %>); <%= "opacity: 0.7;" unless field(:active) %>"
    >
      <%= field(:mark) %>
    </div>
    <% if field(:image) %>
      <img
        src="<%= field(:image) %>"
        alt=""
        loading="lazy"
        onerror="this.style.display='none'"
        class="absolute inset-0 w-full h-full rounded-[10px] object-cover"
        style="<%= "opacity: 0.7;" unless field(:active) %>"
      />
    <% end %>
  </div>
  <div>
    <%= render Text.new(as: :div, variant: :row_title, class: "mb-0.5") do %><%= field(:name) %><% end %>
    <%= render Text.new(as: :div, variant: :card_body) do %><%= field(:tagline) %><% end %>
    <% if meta_parts.any? %>
      <%= render Text.new(as: :div, variant: :meta, class: "mt-1.5") do %><%= meta_parts.join(" · ") %><% end %>
    <% end %>
  </div>
  <%= render Text.new(as: :div, variant: :eyebrow, class: "whitespace-nowrap max-sm:mt-1") do %><%= field(:role) %><% end %>
<% end %>
