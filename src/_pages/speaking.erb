---
layout: default
title: Speaking
permalink: /speaking/
description: Talks I've given, podcasts I host, shows I've been on, and CFPs I've submitted. Want me on yours? Get in touch.
---

<% podcasts = site.data.podcasts %>
<% active_pods = podcasts.select { |p| p["active"] } %>
<% past_pods = podcasts.reject { |p| p["active"] } %>
<% talks = site.data.talks.sort_by { |t| t["date"] }.reverse %>
<% appearances = site.data.appearances.sort_by { |a| a["date"].to_s }.reverse %>
<% cfps = collections.cfps.resources.sort_by(&:date).reverse %>
<% latest_episode = site.data.remote_ruby %>

<%= render PageShell.new do %>
  <%= render Ui::PageHeader.new(
    title: "Speaking",
    description: data.description.sub("Get in touch.", ""),
    description_link_label: "Get in touch",
    description_link_href: "mailto:hello@andrewmcodes.dev",
  ) %>

  <% if active_pods.any? %>
    <%= render PageSection.new do %>
      <%= render SectionHead.new(
        title: "Podcasts / currently hosting",
        description:
          "Shows I'm actively hosting or involved with, plus the latest Remote Ruby episode.",
        bordered: true,
      ) %>
      <%= render Stack.new do %>
        <% active_pods.each do |p| %>
          <%= render PodRow.new(pod: p) %>
        <% end %>
      <% end %>
      <% if latest_episode %>
        <%= render EpisodeCard.new(episode: latest_episode) %>
      <% end %>
    <% end %>
  <% end %>

  <% if past_pods.any? %>
    <%= render PageSection.new do %>
      <%= render SectionHead.new(
        title: "Podcasts / previously",
        description:
          "Shows I used to host or appear on regularly, kept here for context and archives.",
        bordered: true,
      ) %>
      <%= render Stack.new do %>
        <% past_pods.each do |p| %>
          <%= render PodRow.new(pod: p) %>
        <% end %>
      <% end %>
    <% end %>
  <% end %>

  <%= render PageSection.new do %>
    <%= render SectionHead.new(
      title: "Talks",
      description:
        "Conference talks and presentations I've given about Rails, Ruby, software teams, and developer workflows.",
      bordered: true,
    ) %>
    <%= render Stack.new do %>
      <% talks.each do |t| %>
        <%= render TalkCard.new(talk: t) %>
      <% end %>
    <% end %>
  <% end %>

  <% if cfps.any? %>
    <%= render PageSection.new do %>
      <%= render SectionHead.new(
        title: "CFPs",
        description:
          "Conference proposals I've submitted over the years. Some accepted, most not. I keep them around because the writeups are still useful.",
        bordered: true,
      ) %>
      <%= render Stack.new do %>
        <% cfps.each do |c| %>
          <%= render MetaRow.new(
            href: c.relative_url,
            date: c.date.strftime("%b %Y"),
            title: c.data.title,
            meta: [c.data.event, c.data.status],
          ) %>
        <% end %>
      <% end %>
    <% end %>
  <% end %>

  <%= render PageSection.new(spacing: :none) do %>
    <%= render SectionHead.new(
      title: "Appearances",
      description:
        "Guest spots, interviews, and conference appearances from around the Ruby community.",
      bordered: true,
    ) %>
    <%= render Stack.new do %>
      <% appearances.each do |a| %>
        <%= render MetaRow.new(
          href: a["url"],
          date: a["date"],
          title: a["title"],
          meta: [a["event"]],
          external: true,
          title_icon: true,
        ) %>
      <% end %>
    <% end %>
  <% end %>
<% end %>
