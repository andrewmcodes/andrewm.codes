---
layout: default
title: Posts
permalink: /posts/
description: Notes on Rails, podcasting, and the long unglamorous middle. Occasionally proofread.
---

<% posts = collections.posts.resources %>

<% tag_counts =
  posts
    .flat_map { |p| Array(p.data.tags) }
    .tally
    .sort_by { |_, n| -n }
    .first(12) %>

<% years = posts.group_by { |p| p.date.year }.sort.reverse %>

<%= render PageShell.new do %>
  <%= render Ui::PageHeader.new(title: "Posts", description: data.description) %>

  <%= render TagCloud.new(tags: tag_counts.map(&:first)) %>

  <% years.each do |year, year_posts| %>
    <%= render CollectionGroup.new(title: year) do %>
      <% year_posts.each do |post| %>
        <%= render PostRow.new(post: post) %>
      <% end %>
    <% end %>
  <% end %>

  <%= render Text.new(scheme: :muted, size: :md) do %>
    Looking for talks, podcasts, or projects instead? Visit
    <%= render Link.new(href: "/speaking/", variant: :inline_accent) { "speaking" } %>,
    <%= render Link.new(href: "/projects/", variant: :inline_accent) { "projects" } %>,
    or jump to
    <%= render Link.new(href: "/search/", variant: :inline_accent) { "site search" } %>.
  <% end %>
<% end %>
