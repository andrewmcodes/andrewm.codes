---
title: Text
---

<div class="space-y-6">
  <div class="space-y-2">
    <p class="font-mono text-xs text-sage-10">Sizes</p>
    <%= render Text.new(size: :sm) do %>Small (sm)<% end %>
    <%= render Text.new(size: :md) do %>Medium (md)<% end %>
    <%= render Text.new(size: :lg) do %>Large (lg)<% end %>
    <%= render Text.new(size: :xl) do %>Extra large (xl)<% end %>
  </div>

  <div class="space-y-2">
    <p class="font-mono text-xs text-sage-10">Weights</p>
    <%= render Text.new(weight: :default) do %>Normal weight<% end %>
    <%= render Text.new(weight: :medium) do %>Medium weight<% end %>
    <%= render Text.new(weight: :semibold) do %>Semibold weight<% end %>
    <%= render Text.new(weight: :bold) do %>Bold weight<% end %>
  </div>

  <div class="space-y-2">
    <p class="font-mono text-xs text-sage-10">Schemes</p>
    <%= render Text.new(scheme: :strong) do %>Strong<% end %>
    <%= render Text.new(scheme: :muted) do %>Muted<% end %>
    <%= render Text.new(scheme: :primary) do %>Primary<% end %>
  </div>

  <div class="space-y-2">
    <p class="font-mono text-xs text-sage-10">Variants</p>
    <%= render Text.new(variant: :lead) do %>Lead paragraph copy under a page or section header.<% end %>
    <%= render Text.new(as: :div, variant: :card_body) do %>Card body copy for descriptions and abstracts.<% end %>
    <%= render Text.new(as: :div, variant: :meta) do %>Jul 11, 2026 · 4 min<% end %>
    <%= render Text.new(as: :div, variant: :eyebrow) do %>Section label<% end %>
    <%= render Text.new(as: :div, variant: :row_title) do %>List/row title (post, talk, episode, pod)<% end %>
    <%= render Text.new(as: :div, variant: :card_title) do %>Grid card title (project, featured)<% end %>
  </div>
</div>
