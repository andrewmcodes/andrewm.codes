---
title: TagCloud
---

<div class="space-y-6">
  <div class="space-y-2">
    <p class="font-mono text-xs text-sage-10">Default</p>
    <%= render TagCloud.new(
      tags: %w[ruby rails bridgetown viewcomponent tailwind open-source],
    ) %>
  </div>

  <div class="space-y-2">
    <p class="font-mono text-xs text-sage-10">Custom label</p>
    <%= render TagCloud.new(tags: %w[podcasting speaking], label: "topics") %>
  </div>
</div>
