#!/usr/bin/env ruby
# frozen_string_literal: true

#
# This file was generated by Bundler.
#
# The application 'bridgetown' is installed as part of a gem, and
# this file is here to facilitate running it.
#

ENV["BUNDLE_GEMFILE"] ||= File.expand_path("../Gemfile", __dir__)

# Cloudflare Pages skips dev/test groups during `bundle install`, and
# Bundler 4 no longer persists --without, so without this hint
# `Bundler.setup` would fail trying to materialize gems it never installed
# (standard, minitest, debug, etc). GitHub Actions installs all groups via
# bundler-cache, so this is scoped to CF_PAGES only — the Rakefile relies
# on the :test group (minitest/test_task) being loadable in CI.
if ENV["BUNDLE_WITHOUT"].to_s.empty? && ENV["CF_PAGES"]
  ENV["BUNDLE_WITHOUT"] = "development:test"
end

require "rubygems"
require "bundler/setup"

load Gem.bin_path("bridgetown-core", "bridgetown")
